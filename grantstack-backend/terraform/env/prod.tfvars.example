aws_region   = "us-east-1"
project_name = "grantstack"
environment  = "prod"

allowed_origins = [
  "https://grantstack.example.com"
]

jwt_authorizer = {
  enabled  = true
  issuer   = "https://issuer.example.com/"
  audience = ["grantstack-prod"]
}

mock_external_calls = false

llm_provider                 = "openai"
llm_api_endpoint             = "https://api.openai.com/v1/chat/completions"
llm_api_key_secret_arn       = "arn:aws:secretsmanager:us-east-1:123456789012:secret:grantstack/prod/openai"
llm_model                    = "gpt-4.1-mini"
embedding_provider           = "openai"
embedding_api_endpoint       = "https://api.openai.com/v1/embeddings"
embedding_api_key_secret_arn = "arn:aws:secretsmanager:us-east-1:123456789012:secret:grantstack/prod/openai"
embedding_model              = "text-embedding-3-small"
vector_db_provider           = "pinecone"
vector_db_endpoint           = "https://your-prod-index.svc.aped-4627-b74a.pinecone.io"
vector_db_api_key_secret_arn = "arn:aws:secretsmanager:us-east-1:123456789012:secret:grantstack/prod/pinecone"
vector_db_namespace          = "grantstack-incentives-prod"
vector_db_top_k              = 10
vector_db_min_score          = 0.2
vector_db_api_version        = ""
http_client_timeout_seconds  = 30

project_ttl_days         = 90
analytics_ttl_days       = 180
api_throttle_burst_limit = 100
api_throttle_rate_limit  = 50

enable_xray_tracing         = true
enable_api_access_logs      = true
enable_cloudwatch_dashboard = true
enable_source_refresh       = true

processor_memory_size          = 1024
processor_timeout_seconds      = 900
sqs_visibility_timeout_seconds = 960
dlq_max_receive_count          = 3
log_retention_in_days          = 90

enable_cloudwatch_alarms = true
alarm_actions            = []

tags = {
  Owner       = "platform"
  CostProfile = "production"
}
