aws_region   = "us-east-1"
project_name = "grantstack"
environment  = "staging"

allowed_origins = [
  "https://staging.grantstack.example.com"
]

jwt_authorizer = {
  enabled  = true
  issuer   = "https://issuer.example.com/"
  audience = ["grantstack-staging"]
}

mock_external_calls = false

llm_provider                 = "openai"
llm_api_endpoint             = "https://api.openai.com/v1/chat/completions"
llm_api_key_secret_arn       = "arn:aws:secretsmanager:us-east-1:123456789012:secret:grantstack/staging/openai"
llm_model                    = "gpt-4.1-mini"
embedding_provider           = "openai"
embedding_api_endpoint       = "https://api.openai.com/v1/embeddings"
embedding_api_key_secret_arn = "arn:aws:secretsmanager:us-east-1:123456789012:secret:grantstack/staging/openai"
embedding_model              = "text-embedding-3-small"
vector_db_provider           = "pinecone"
vector_db_endpoint           = "https://your-staging-index.svc.aped-4627-b74a.pinecone.io"
vector_db_api_key_secret_arn = "arn:aws:secretsmanager:us-east-1:123456789012:secret:grantstack/staging/pinecone"
http_client_timeout_seconds  = 30

project_ttl_days         = 30
api_throttle_burst_limit = 30
api_throttle_rate_limit  = 15

enable_xray_tracing         = true
enable_api_access_logs      = true
enable_cloudwatch_dashboard = true
enable_source_refresh       = true

processor_memory_size          = 1024
processor_timeout_seconds      = 900
sqs_visibility_timeout_seconds = 960
dlq_max_receive_count          = 3
log_retention_in_days          = 30

enable_cloudwatch_alarms = true
alarm_actions            = []

tags = {
  Owner       = "platform"
  CostProfile = "staging"
}
